    "test": "env $(cat .env.test | xargs) npx vitest run"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "zod": "^3.23.8",
    "@prisma/client": "^5.19.1"
  },
  "devDependencies": {
    "prisma": "^5.19.1",
    "typescript": "^5.5.4",
    "tsx": "^4.19.0",
    "vitest": "^2.0.5",
    "@types/node": "^22.5.0"
  }
}
