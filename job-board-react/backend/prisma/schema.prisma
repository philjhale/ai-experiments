generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Job {
  id             Int      @id @default(autoincrement())
  title          String
  company        String
  location       String
  description    String
  employmentType String
  locationType   String
  applicationUrl String
  postedDate     DateTime @default(now())
}
