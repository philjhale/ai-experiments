@page "/"
@rendermode InteractiveServer
@inject JobService JobService
@inject IJSRuntime JSRuntime

<PageTitle>Job Board</PageTitle>

<h1>Job Board</h1>

<a class="btn btn-primary mb-3" href="/post">Post a Job</a>

@if (jobs is null)
{
    <p><em>Loading...</em></p>
}
else if (jobs.Count == 0)
{
    <p>No jobs posted yet. Be the first!</p>
}
else
{
    @foreach (var job in jobs)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@job.Title</h5>
                <h6 class="card-subtitle mb-2 text-muted">@job.Company &middot; @job.Location</h6>
                <p class="card-text">
                    <span class="badge bg-secondary">@job.EmploymentType</span>
                    <span class="badge bg-secondary">@job.LocationType</span>
                </p>
                <p class="card-text">@job.Description</p>
                <p class="card-text"><small class="text-muted">Posted @job.PostedDate.ToLocalTime().ToString("g")</small></p>
                <a class="btn btn-outline-primary" href="@job.ApplicationUrl" rel="noopener noreferrer">Apply</a>
                <a class="text-danger small ms-3" href="#" @onclick="() => DeleteJobAsync(job)" @onclick:preventDefault>Delete</a>
            </div>
        </div>
    }
}

@code {
    private List<Job>? jobs;

    protected override async Task OnInitializedAsync()
    {
        jobs = await JobService.GetAllJobsAsync();
    }

    private async Task DeleteJobAsync(Job job)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Delete \"{job.Title}\"?");
        if (!confirmed)
        {
            return;
        }

        await JobService.DeleteJobAsync(job.Id);
        jobs?.Remove(job);
    }
}
